{
  "name": "zero-zero-app",
  "version": "1.0.0",
  "type": "module",
  "description": "Zero Zero - Sustainability app for saving money, reducing carbon footprint, and improving well-being",
  "homepage": "https://zero-zero.app",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run type-check",
    "deploy": "npm run build && npm run preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@types/node": "^20.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.294.0",
    "next-themes": "^0.4.6",
    "sonner": "^1.3.1",
    "tailwindcss": "^4.0.0-alpha.4",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5"
  },
  "keywords": [
    "sustainability",
    "carbon-footprint",
    "environmental",
    "green-tech",
    "climate-action",
    "react",
    "typescript",
    "supabase"
  ],
  "author": "Zero Zero Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}