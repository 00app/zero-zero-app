{
  "name": "zero-zero-app",
  "version": "1.0.0",
  "type": "module",
  "description": "zero zero - sustainability app for saving money, reducing carbon footprint, and improving well-being",
  "homepage": "https://zero-zero.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/00app/zero-zero-app.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "verify": "node verify-build.js",
    "deploy-ready": "npm run verify && echo 'Ready for deployment!'",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.294.0",
    "sonner": "^1.3.1",
    "@supabase/supabase-js": "^2.45.4",
    "framer-motion": "^11.0.0",
    "react-hook-form": "7.55.0",
    "zod": "^3.22.4",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-slider": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "recharts": "^2.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33"
  },
  "keywords": [
    "sustainability",
    "carbon-footprint",
    "environmental",
    "green-tech",
    "climate-action",
    "react",
    "typescript"
  ],
  "author": "zero zero team",
  "license": "MIT",
  "engines": {
    "node": "18",
    "npm": ">=8.19.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}