{
  "name": "zero-zero-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Zero Zero - Sustainable lifestyle app with AI-powered tips",
  "scripts": {
    "dev": "node fix-structure.js && vite",
    "build": "node fix-structure.js && tsc --noEmit && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "clean": "rm -rf dist build src lib .vite node_modules/.cache",
    "fix": "node fix-structure.js",
    "cleanup": "node fix-structure.js",
    "type-check": "node fix-structure.js && tsc --noEmit --skipLibCheck",
    "verify": "npm run fix && npm run validate && npm run type-check",
    "postinstall": "node fix-structure.js",
    "start": "npm run dev",
    "test-env": "node validate-env.js",
    "validate": "node validate-env.js",
    "check-structure": "node validate-env.js",
    "deploy": "npm run verify && npm run build",
    "deploy-check": "node deploy-check.js",
    "emergency-fix": "rm -rf src lib dist build .vite && node fix-structure.js",
    "final-fix": "node FINAL-FIX.js"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.4",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-toggle-group": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@supabase/supabase-js": "^2.46.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^0.2.0",
    "date-fns": "^2.30.0",
    "embla-carousel-react": "^8.0.0",
    "framer-motion": "^10.16.5",
    "input-otp": "^1.2.4",
    "lucide-react": "^0.295.0",
    "openai": "^4.20.1",
    "react": "^18.2.0",
    "react-day-picker": "^8.9.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.47.0",
    "react-resizable-panels": "^0.0.55",
    "recharts": "^2.8.0",
    "sonner": "^1.2.0",
    "tailwind-merge": "^2.1.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.7.9"
  },
  "devDependencies": {
    "@types/node": "^20.9.5",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^4.5.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.19.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/00app/zero-zero-app"
  },
  "keywords": [
    "sustainability",
    "carbon-footprint",
    "ai-assistant",
    "react",
    "typescript",
    "vite"
  ],
