{
  "name": "zero-zero-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Zero Zero - A sustainability app that helps users save money, reduce their carbon footprint, and improve well-being through real-time data and AI-powered insights",
  "engines": {
    "node": "16.x",
    "npm": "10.8.2"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf dist node_modules/.cache",
    "clean:cache": "npm cache clean --force && rm -rf node_modules/.cache && rm -rf dist",
    "validate": "node validate-env.js",
    "test-env": "node validate-env.js",
    "prebuild": "npm run clean",
    "postbuild": "node verify-build.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.3.0",
    "supabase-js": "^2.39.0",
    "axios": "^0.26.1",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "sass": "^1.49.9"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite-plugin-svgr": "^2.3.0",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zerozero/zero-zero-app.git"
  },
  "keywords": [
    "sustainability",
    "carbon-footprint",
    "environment",
    "react",
    "typescript",
    "vite",
    "netlify"
  ],
  "author": "Zero Zero Team",
  "license": "MIT",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "countryRegion": {
    "United Kingdom": {
      "region": "UK",
      "carbonEmission": "2025-07-16",
      "currency": "GBP",
      "ecoTips": "Use public transport, switch off lights when not in use"
    },
    "Europe": {
      "region": "Europe",
      "carbonEmission": "2025-07-16",
      "currency": "EUR",
      "ecoTips": "Consider walking or cycling, reduce single-use plastics"
    },
    "Australia": {
      "region": "AUS",
      "carbonEmission": "2025-07-16",
      "currency": "AUD",
      "ecoTips": "Use solar energy, recycle waste materials"
    }
  }
}
